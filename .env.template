# Database — provided by Railway PostgreSQL service
DATABASE_URL=postgresql://user:password@host:5432/railway

# Redis — provided by Railway Redis service  
REDIS_URL=redis://default:password@host:6379

# Secrets — generate with: openssl rand -base64 32
JWT_SECRET=change-me-in-production
COOKIE_SECRET=change-me-in-production

# Your deployed backend URL (set after first deploy)
MEDUSA_BACKEND_URL=https://your-app.up.railway.app

# CORS — add your storefront URL here
STORE_CORS=http://localhost:3002,https://iwill.bg
ADMIN_CORS=http://localhost:9000,https://app.medusajs.com
AUTH_CORS=http://localhost:9000,https://app.medusajs.com,https://iwill.bg

# Node
NODE_ENV=production
